APP_NAME=Calm
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ADMIN_PASSWORD=

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Comma-separated emails that get internal alerts on important events (new paid
# booking, payment failure, new place submitted). Empty = owner alerts off.
OWNER_EMAILS=

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_DEFAULT_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_URL=
S3_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_MAPS_API_KEY=

VITE_APP_NAME="${APP_NAME}"

# JWT (php-open-source-saver/jwt-auth)
JWT_COOKIE_NAME=calm_token
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=lax
# Token lifetimes (minutes). Admins get JWT_TTL (short — dashboard sessions);
# guests/hosts get JWT_USER_TTL (long — app sessions, default 180 days).
# JWT_REFRESH_TTL must exceed JWT_USER_TTL or app tokens can't refresh.
JWT_TTL=60
JWT_USER_TTL=259200
JWT_REFRESH_TTL=302400

# Page size for every list (API + admin). Clients can't override it.
PAGINATION_PER_PAGE=20

# Push notifications — DISABLED for now (ship with SMS + in-app only). Flip
# PUSH_ENABLED=true + PUSH_DRIVER=expo once the mobile app registers Expo tokens.
# EXPO_ACCESS_TOKEN only needed if Expo "Enhanced Security for Push" is enabled.
PUSH_ENABLED=false
PUSH_DRIVER=mock
EXPO_ACCESS_TOKEN=

# SMS gateway — `mock` writes to laravel.log; `sms_saudi` hits the real API.
# Production MUST use `sms_saudi`; `mock` issues a fixed code (111111).
SMS_DRIVER=mock
SMS_SAUDI_API_KEY=
SMS_SAUDI_SENDER=
SMS_SAUDI_LANGUAGE=1

# Comma-separated phones that always use the MOCK sms driver (fixed OTP 111111,
# no real SMS — OTP or notifications) even when SMS_DRIVER=sms_saudi. For testers
# / App Store review. Matched on the last 9 digits (0501234567 / +966501234567 /
# 501234567 all work).
SMS_MOCK_PHONES=0500000000

# Moyasar (hosted payment page + webhook). secret_key is the HTTP basic-auth
# username; webhook_secret is the shared `secret_token` echoed back per webhook.
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
MOYASAR_BASE_URL=https://api.moyasar.com/v1/
MOYASAR_SUCCESS_URL=
MOYASAR_BACK_URL=
MOYASAR_HOLD_MINUTES=10
# Invoice closes this many minutes before the date hold (safety buffer).
MOYASAR_INVOICE_BUFFER_MINUTES=1

# Moyasar Payouts (automatic host transfers). `manual` PAUSES the sweep —
# payouts queue and admins settle via "Mark paid manually" on the booking
# page. Flip to `auto` only after Moyasar activates Payouts on the account
# and the company source bank account is registered (id below).
MOYASAR_PAYOUTS_MODE=manual
MOYASAR_PAYOUT_ACCOUNT_ID=
# Must stay `payment_to_merchant` — IPS rejects most other purposes post-create.
MOYASAR_PAYOUT_PURPOSE=payment_to_merchant
MOYASAR_PAYOUT_DEFAULT_CITY=Riyadh

# Qoyod accounting mirror (invoices, receipts, credit notes, vouchers).
# Products are created ONCE per org and never deleted; account ids come from
# the org's chart of accounts. Keep QOYOD_ENABLED=false until all ids are set.
QOYOD_ENABLED=false
QOYOD_API_KEY=
QOYOD_BASE_URL=https://api.qoyod.com/2.0
QOYOD_PRODUCT_STAY_ID=
QOYOD_PRODUCT_COMMISSION_ID=
QOYOD_MOYASAR_ACCOUNT_ID=
QOYOD_SETTLEMENT_ACCOUNT_ID=
QOYOD_INVENTORY_ID=1

# Hours after checkout before invoices are issued (tax documents + the payout
# unlock depend on it). Leave unset in production for the 4h default.
# FINANCE_INVOICE_ISSUE_HOURS=4
