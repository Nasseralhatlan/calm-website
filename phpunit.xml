<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <!-- Integration flags pinned OFF so local .env state (live testing
             against real Qoyod/Moyasar) can never leak into the suite. -->
        <env name="QOYOD_ENABLED" value="false"/>
        <env name="QOYOD_API_KEY" value=""/>
        <env name="MOYASAR_PAYOUTS_MODE" value="manual"/>
        <env name="MOYASAR_PAYOUT_ACCOUNT_ID" value=""/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!-- Force the in-memory SMS mock during tests so any code path going
             through the DI container can NEVER reach the real SMS gateway,
             even if a developer's local .env has SMS_DRIVER=sms_saudi. -->
        <env name="SMS_DRIVER" value="mock"/>
        <!-- Defang any accidental real outbound HTTP — also blocks the gateway
             at the network layer. tests/Pest.php pairs this with
             Http::preventStrayRequests() so unfaked requests throw loudly. -->
        <env name="SMS_SAUDI_API_KEY" value="TEST_DO_NOT_USE"/>
        <env name="SMS_SAUDI_SENDER" value="TestSender"/>
    </php>
</phpunit>
